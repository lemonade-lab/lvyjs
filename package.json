{
  "name": "lvy",
  "version": "1.0.0",
  "description": "一款为 node 构建设计的开发工具",
  "author": "lemonade",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npx lvy src/index.ts",
    "build": "npx lvy build",
    "bundle": "npx lerna run build",
    "test": "jest",
    "format": "prettier --write .",
    "check-format": "git diff --exit-code",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.25.7",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "husky": "^9.0.11",
    "jest": "^30.3.0",
    "less": "^4.6.4",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.1"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@1.22.22"
}
